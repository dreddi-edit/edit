# Site Editor – Environment Template
# Copy to server/.env and fill in real values. Never commit .env.
# If .env was ever committed to git, rotate ALL keys immediately.

# Auth (required in production)
JWT_SECRET=your-secret-min-32-chars
OWNER_EMAIL=admin@example.com

# OAuth providers (optional - add real values to enable buttons)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# AI (pick what you need)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Google (PageSpeed, SEO audit, etc.)
GOOGLE_API_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=
APP_URL=https://your-app.com
# Optional: force all password-reset mails to a single inbox for local/dev testing
PASSWORD_RESET_EMAIL_OVERRIDE=

# Database (optional, defaults to ./data/editor.db)
DB_PATH=./data/editor.db

# Server
PORT=8787
NODE_ENV=production

# CORS (required in production – comma-separated origins, no *)
ALLOWED_ORIGIN=https://your-app.com
